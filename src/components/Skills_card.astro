---
const { skills } = Astro.props;
---

<div class="skills_card">
  <ul>
    {skills && skills.map((item) => <li>{item}</li>)}
  </ul>
</div>

<style>
  .skills_card {
    background-color: var(--nice-gray);
    border: 2px solid var(--card-border);
    border-radius: 12px;
    padding: 1.5rem;
    box-shadow: var(--shadow-sm);
  }

  .skills_card ul {
    font-size: 1.1rem;
    display: grid;
    gap: 0.75rem;
    grid-template-columns: 1fr;
    list-style: none;
    margin: 0;
    padding: 0;

    @media (width >= 640px) {
      grid-template-columns: 1fr 1fr;
    }

    @media (width >= 960px) {
      grid-template-columns: 1fr 1fr;
      font-size: 1.2rem;
    }

    li {
      padding: 0.5rem 1rem;
      background-color: rgba(69, 123, 157, 0.15);
      border-radius: 6px;
      border: 1px solid rgba(69, 123, 157, 0.25);
      transition: background-color var(--transition-base);
    }

    li:hover {
      background-color: rgba(69, 123, 157, 0.3);
    }
  }
</style>
