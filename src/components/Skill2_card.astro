---
const { title, body } =
  Astro.props;
---

<div class="card">
  <h3>{title}</h3>
  <p>{body}</p>

<style>
  .card {
    background-color: var(--nice-gray);
    border: 2px solid var(--primary-color);
    border-radius: 0 1em 0 1em;
    width: 95%%;
    height: relative;
    position: relative;
    display: flex;
    flex-direction: column;
  }

  .card h3 {
    font-size: 1.8rem;
    margin-left: 1rem;
    font-weight: 100;
    color: var(--title-color);
    margin: 0;
    padding-left: 1rem;
    padding-top: 1rem;

    @media (width >= 640px) {
      font-size: 2rem;
    }

    @media (width >= 960px) {
      font-size: 2.75rem;
    }
  }

  .card p {
    font-size: 1.1rem;
    margin-right: 1rem;
    font-weight: 100;
    color: var(--text-color);
    margin: 0;
    padding-right: 0.75rem;

    @media (width >= 640px) {
      font-size: 1.5rem;
    }

    @media (width >= 960px) {
      font-size: 1.75rem;
    }
  }
</style>
