<style>
  .section__container {
    background-color: var(--nice-gray);
    height: calc(100vh - 70px);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
  }

  h1 {
    margin-bottom: 0.5rem;
  }

  .contact__subtitle {
    color: var(--text-color);
    opacity: 0.7;
    margin: 0 0 3rem 0;
    padding: 0;
    font-size: 1.1rem;
  }

  .contact__links {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;

    @media (width >= 640px) {
      flex-direction: row;
      gap: 2rem;
    }
  }

  .contact__links a {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 1.2rem;
    color: var(--text-color);
    text-decoration: none;
    padding: 1rem 1.5rem;
    border-radius: 12px;
    border: 1px solid var(--card-border);
    background-color: rgba(69, 123, 157, 0.08);
    transition: background-color var(--transition-base), transform var(--transition-base), border-color var(--transition-base);

    @media (width >= 640px) {
      font-size: 1.3rem;
      padding: 1.2rem 2rem;
    }
  }

  .contact__links a:hover {
    background-color: rgba(69, 123, 157, 0.2);
    border-color: var(--primary-color);
    transform: translateY(-2px);
  }

  .contact__links a svg {
    flex-shrink: 0;
  }

</style>
