---
const { title, date, place, description, listItems, image, name, ref } =
  Astro.props;
---

<div class="card">
  <div class="card__header"> 
   <a href={ref} target="_blank" rel="noopener noreferrer">
      <img src={image} alt={name} />
    </a>
    <div class="card__header-text">
      <h3>{title}</h3>
      <h4>{date} | {place}</h4>
    </div>
  </div>
  <p class="card__description">{description}</p>
  <ul>
    {listItems && listItems.map((item) => <li>{item}</li>)}
  </ul>
</div>


<style>
  .card {
    background-color: var(--nice-gray);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    padding: 1.5rem;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
    box-shadow: var(--shadow-sm);
  }

  .card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  .card__header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .card__header img {
    height: 3.5rem;
    width: auto;
    max-width: 8rem;
    object-fit: contain;
  }

  .card__header-text h3 {
    font-size: 1.4rem;
    font-weight: 400;
    color: var(--title-color);
    margin: 0;

    @media (width >= 640px) {
      font-size: 1.6rem;
    }

    @media (width >= 960px) {
      font-size: 2rem;
    }
  }

  .card__header-text h4 {
    font-size: 0.95rem;
    font-weight: 300;
    color: var(--text-color);
    opacity: 0.7;
    margin: 0.25rem 0 0 0;

    @media (width >= 640px) {
      font-size: 1.05rem;
    }

    @media (width >= 960px) {
      font-size: 1.15rem;
    }
  }


  .card p {
    font-size: 1.2rem;
    margin-right: 1rem;
    font-weight: 100;
    color: var(--text-color);
    margin: 0;
    padding-right: 0.75rem;

    @media (width >= 640px) {
      font-size: 1.5rem;
    }

    @media (width >= 960px) {
      font-size: 1.75rem;
    }
  }

  .card__description {
    font-size: 1.1rem;
    color: var(--title-color);
    font-weight: 400;
    margin: 0 0 0.75rem 0;
    padding: 0;
  }

  .card ul {
    font-size: 0.95rem;
    padding-left: 1.2rem;
    margin: 0;

    @media (width >= 640px) {
      font-size: 1.05rem;
    }

    @media (width >= 960px) {
      font-size: 1.1rem;
    }
  }

  .card ul li {
    margin-bottom: 0.6rem;
    line-height: 1.5;
  }

</style>
