---
import Card from "./Project_card.astro";
import data from "../data/projects.json";
const projects = data.projects;
---

<section class="section__container" id="projects">
  <h1>Projects</h1>
  <div class="card-wrapper">
    {
      projects.map((proj) => (
        <Card image={proj.image} link={proj.link} title={proj.title} />
      ))
    }
  </div>
</section>

<style>
  .section__container {
    background-color: var(--secondary-color);
    padding-top: 50px;
    padding-left: 50px;
    padding-right: 50px;
    padding-bottom: 50px;
    height: fit-content;
  }

  .card-wrapper {
    display: grid;
    grid-template-columns: 1fr;
    gap: 5rem;

    @media (width >= 640px) {
      grid-template-columns: 1fr 1fr;
    }

    @media (width >= 960px) {
      font-size: 1.75rem;
    }
  }
</style>
