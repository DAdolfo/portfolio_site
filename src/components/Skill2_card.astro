---
const { title, body } =
  Astro.props;
---

<div class="card">
  <h3>{title}</h3>
  <p>{body}</p>

<style>
  .card {
    background-color: var(--nice-gray);
    border: 1px solid var(--card-border);
    border-radius: 12px;
    padding: 1.5rem;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
    box-shadow: var(--shadow-sm);
  }

  .card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }


  .card h3 {
    font-size: 1.3rem;
    font-weight: 400;
    color: var(--title-color);
    margin: 0 0 0.75rem 0;

    @media (width >= 640px) {
      font-size: 1.5rem;
    }

    @media (width >= 960px) {
      font-size: 1.8rem;
    }
  }

  .card p {
    font-size: 1rem;
    font-weight: 300;
    color: var(--text-color);
    margin: 0;
    line-height: 1.7;
    opacity: 0.9;

    @media (width >= 640px) {
      font-size: 1.05rem;
    }

    @media (width >= 960px) {
      font-size: 1.15rem;
    }
  }
</style>
